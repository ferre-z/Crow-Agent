{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "crow-sidecar",
          "cmd": "../binaries/crow",
          "args": [
            { "validator": ".*" }
          ]
        }
      ]
    },
    "shell:allow-open"
  ]
}
